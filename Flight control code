// ============================================
// PIN DEFINITIONS
// ============================================

// I2C Sensors (MPU6050 + BMP280 share I2C bus)
#define I2C_SDA_PIN     21
#define I2C_SCL_PIN     22

// NRF24L01 SPI Pins
#define NRF_CE_PIN      4
#define NRF_CSN_PIN     5
#define NRF_MOSI_PIN    23
#define NRF_MISO_PIN    19
#define NRF_SCK_PIN     18

// Motor Output Pins (ESC control)
#define MOTOR1_PIN      13  // Front Right (CW)
#define MOTOR2_PIN      12  // Front Left (CCW)
#define MOTOR3_PIN      14  // Rear Left (CW)
#define MOTOR4_PIN      27  // Rear Right (CCW)

// LED Indicators
#define LED_ARMED       2   // Built-in LED or external
#define LED_STATUS      15  // Status indicator
#define LED_ERROR       4   // Error indicator

// Buzzer/Alerts
#define BUZZER_PIN      32

// Battery Monitor
#define BATTERY_PIN     34  // ADC for voltage divider
#define BATTERY_FACTOR  2.0 // Voltage divider ratio (adjust based on your circuit)

// ============================================
// RADIO CONFIGURATION
// ============================================

RF24 radio(NRF_CE_PIN, NRF_CSN_PIN);
const uint64_t pipeIn = 0xE8E8F0F0E1LL;  // Must match transmitter

// Radio packet structure (receiver commands)
struct RadioCommand {
  uint16_t throttle;    // 0-1000 (0-100%)
  int16_t roll;         // -500 to +500
  int16_t pitch;        // -500 to +500
  int16_t yaw;          // -500 to +500
  uint8_t switches;     // Flight mode, arming, etc.
  uint16_t checksum;
};

RadioCommand rcCommand;
unsigned long lastRadioTime = 0;
const unsigned long RADIO_TIMEOUT = 250; // ms - signal loss detection

// ============================================
// SENSOR OBJECTS
// ============================================

Adafruit_MPU6050 mpu;
Adafruit_BMP280 bmp;

// Sensor data structure
struct SensorData {
  float accelX, accelY, accelZ;      // Raw accelerometer (m/s²)
  float gyroX, gyroY, gyroZ;          // Raw gyroscope (rad/s)
  float temperature;                   // Temperature (°C)
  float pressure;                      // Pressure (hPa)
  float altitude;                       // Altitude (m)
  float filteredAlt;                    // Filtered altitude
  unsigned long timestamp;
};

SensorData sensors;

// ============================================
// FLIGHT CONTROL VARIABLES
// ============================================

// Attitude estimation (complementary filter)
float roll = 0.0, pitch = 0.0, yaw = 0.0;
float rollRate = 0.0, pitchRate = 0.0, yawRate = 0.0;
float accelRoll = 0.0, accelPitch = 0.0;

// PID Controllers
struct PIDController {
  float kp, ki, kd;
  float integral;
  float previousError;
  float output;
  unsigned long lastTime;
  
  PIDController(float p = 0, float i = 0, float d = 0) 
    : kp(p), ki(i), kd(d), integral(0), previousError(0), output(0), lastTime(0) {}
  
  float update(float setpoint, float input, float dt) {
    float error = setpoint - input;
    
    // Proportional
    float pTerm = kp * error;
    
    // Integral with anti-windup
    integral += error * dt;
    integral = constrain(integral, -100, 100); // Prevent integral windup
    float iTerm = ki * integral;
    
    // Derivative
    float derivative = (error - previousError) / dt;
    float dTerm = kd * derivative;
    
    // Store for next iteration
    previousError = error;
    
    // Calculate output
    output = pTerm + iTerm + dTerm;
    
    return output;
  }
  
  void reset() {
    integral = 0;
    previousError = 0;
  }
};

// PID instances
PIDController pidRoll(1.5, 0.05, 0.1);    // Tune these values!
PIDController pidPitch(1.5, 0.05, 0.1);
PIDController pidYaw(2.0, 0.1, 0.2);
PIDController pidAltitude(1.0, 0.01, 0.5);

// Motor outputs
int16_t motor1 = 0, motor2 = 0, motor3 = 0, motor4 = 0;
const int MOTOR_MIN = 1000;  // ESC minimum pulse width (μs)
const int MOTOR_MAX = 2000;  // ESC maximum pulse width (μs)
const int MOTOR_IDLE = 1050; // Motor idle speed (just above startup)

// Servo objects for ESC control
Servo esc1, esc2, esc3, esc4;

// ============================================
// SYSTEM STATE
// ============================================

enum FlightMode {
  MODE_STANDBY = 0,
  MODE_ARMED = 1,
  MODE_ALTITUDE_HOLD = 2,
  MODE_FAILSAFE = 3
};

FlightMode currentMode = MODE_STANDBY;
bool isArmed = false;
bool failsafeActive = false;
unsigned long armTime = 0;

// Battery monitoring
float batteryVoltage = 0.0;
const float BATTERY_LOW = 3.5;   // Low voltage threshold (per cell)
const float BATTERY_CRITICAL = 3.3;

