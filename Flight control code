// ============================================
// SETUP FUNCTION
// ============================================

void setup() {
  Serial.begin(115200);
  delay(1000);
  Serial.println(F("\n\n=== ADVANCED ESP32 FLIGHT CONTROLLER ==="));
  Serial.println(F("Initializing systems..."));
  
  // Initialize LED pins
  pinMode(LED_ARMED, OUTPUT);
  pinMode(LED_STATUS, OUTPUT);
  pinMode(LED_ERROR, OUTPUT);
  pinMode(BUZZER_PIN, OUTPUT);
  
  digitalWrite(LED_ARMED, LOW);
  digitalWrite(LED_STATUS, LOW);
  digitalWrite(LED_ERROR, LOW);
  
  // Startup beep
  tone(BUZZER_PIN, 1000, 200);
  delay(200);
  
  // Initialize I2C for sensors
  Wire.begin(I2C_SDA_PIN, I2C_SCL_PIN);
  Wire.setClock(400000); // Fast mode for better performance
  
  // Initialize all subsystems
  bool initSuccess = true;
  
  Serial.print(F("Initializing sensors... "));
  if (!initSensors()) {
    Serial.println(F("❌ FAILED"));
    initSuccess = false;
  } else {
    Serial.println(F("✅ OK"));
  }
  
  Serial.print(F("Initializing radio... "));
  if (!initRadio()) {
    Serial.println(F("❌ FAILED"));
    initSuccess = false;
  } else {
    Serial.println(F("✅ OK"));
  }
  
  Serial.print(F("Initializing motors... "));
  initMotors();
  Serial.println(F("✅ OK"));
  
  if (!initSuccess) {
    Serial.println(F("\n⚠️  CRITICAL ERROR - System halted!"));
    while (1) {
      // Error indicator: fast blinking
      digitalWrite(LED_ERROR, HIGH);
      tone(BUZZER_PIN, 2000, 100);
      delay(100);
      digitalWrite(LED_ERROR, LOW);
      delay(100);
    }
  }
  
  // Calibration tone
  tone(BUZZER_PIN, 1500, 300);
  delay(300);
  tone(BUZZER_PIN, 2000, 300);
  
  Serial.println(F("\n✅ SYSTEM READY - Waiting for arm command"));
  Serial.println(F("===========================================\n"));
  
  // Initial sensor read for attitude calculation
  readSensors();
  delay(100);
}

// ============================================
// MAIN LOOP
// ============================================

void loop() {
  static unsigned long lastLoopTime = 0;
  static unsigned long lastTelemetryTime = 0;
  unsigned long currentTime = micros();
  float dt = (currentTime - lastLoopTime) / 1000000.0; // Convert to seconds
  dt = constrain(dt, 0.001, 0.01); // Limit to reasonable values
  
  // Read sensors (400Hz update rate)
  readSensors();
  
  // Update attitude estimation
  updateAttitude();
  
  // Check radio link
  checkRadio();
  
  // Check battery voltage
  checkBattery();
  
  // Update flight control if armed and radio OK
  if (isArmed && !failsafeActive) {
    updatePID(dt);
    calculateMotorMix();
    setMotors();
  } else if (failsafeActive) {
    // Failsafe: gradually reduce motors
    motor1 *= 0.95;
    motor2 *= 0.95;
    motor3 *= 0.95;
    motor4 *= 0.95;
    setMotors();
  } else {
    // Motors stopped
    motor1 = motor2 = motor3 = motor4 = MOTOR_MIN;
    setMotors();
  }
  
  // Send telemetry (10Hz)
  if (currentTime - lastTelemetryTime > 100000) {
    sendTelemetry();
    lastTelemetryTime = currentTime;
  }
  
  // Update status LEDs
  indicateStatus();
  
  lastLoopTime = currentTime;
  
  // Small delay to prevent watchdog issues
  delay(1);
}

// ============================================
// INITIALIZATION FUNCTIONS
// ============================================

bool initSensors() {
  // Initialize MPU6050
  if (!mpu.begin()) {
    Serial.println(F("MPU6050 not found!"));
    return false;
  }
  
  // Configure MPU6050 for flight controller use
  mpu.setAccelerometerRange(MPU6050_RANGE_8_G);
  mpu.setGyroRange(MPU6050_RANGE_500_DEG);
  mpu.setFilterBandwidth(MPU6050_BAND_21_HZ); // Good balance of noise and response
  
  // Initialize BMP280
  if (!bmp.begin(0x76)) {
    if (!bmp.begin(0x77)) {
      Serial.println(F("BMP280 not found!"));
      return false;
    }
  }
  
  // Configure BMP280
  bmp.setSampling(Adafruit_BMP280::MODE_NORMAL,
                  Adafruit_BMP280::SAMPLING_X2,   // Temperature oversampling
                  Adafruit_BMP280::SAMPLING_X16,  // Pressure oversampling
                  Adafruit_BMP280::FILTER_X16,    // Filtering
                  Adafruit_BMP280::STANDBY_MS_500);
  
  return true;
}

bool initRadio() {
  if (!radio.begin()) {
    return false;
  }
  
  // Configure NRF24L01 for reliable communication
  radio.setChannel(100);
  radio.setDataRate(RF24_250KBPS);  // Better range
  radio.setPALevel(RF24_PA_HIGH);    // Maximum power
  radio.setPayloadSize(sizeof(RadioCommand));
  radio.setAutoAck(true);
  radio.setRetries(5, 15);
  
  // Open pipe for reading
  radio.openReadingPipe(1, pipeIn);
  radio.startListening();
  
  return true;
}

void initMotors() {
  // Allow ESP32Servo to use timers
  ESP32PWM::allocateTimer(0);
  ESP32PWM::allocateTimer(1);
  ESP32PWM::allocateTimer(2);
  ESP32PWM::allocateTimer(3);
  
  // Attach ESCs to pins
  esc1.setPeriodHertz(50);      // Standard ESC frequency (50Hz)
  esc2.setPeriodHertz(50);
  esc3.setPeriodHertz(50);
  esc4.setPeriodHertz(50);
  
  esc1.attach(MOTOR1_PIN, MOTOR_MIN, MOTOR_MAX);
  esc2.attach(MOTOR2_PIN, MOTOR_MIN, MOTOR_MAX);
  esc3.attach(MOTOR3_PIN, MOTOR_MIN, MOTOR_MAX);
  esc4.attach(MOTOR4_PIN, MOTOR_MIN, MOTOR_MAX);
  
  // Initialize to minimum throttle
  esc1.writeMicroseconds(MOTOR_MIN);
  esc2.writeMicroseconds(MOTOR_MIN);
  esc3.writeMicroseconds(MOTOR_MIN);
  esc4.writeMicroseconds(MOTOR_MIN);
  
  delay(1000); // Give ESCs time to initialize
}

// ============================================
// SENSOR READING FUNCTIONS
// ============================================

void readSensors() {
  static float seaLevelPressure = 1013.25;
  static float altitudeOffset = 0;
  static bool firstReading = true;
  
  // Get MPU6050 data
  sensors_event_t a, g, temp;
  mpu.getEvent(&a, &g, &temp);
  
  // Store raw sensor values
  sensors.accelX = a.acceleration.x;
  sensors.accelY = a.acceleration.y;
  sensors.accelZ = a.acceleration.z;
  sensors.gyroX = g.gyro.x;
  sensors.gyroY = g.gyro.y;
  sensors.gyroZ = g.gyro.z;
  
  // Get BMP280 data
  sensors.temperature = bmp.readTemperature();
  sensors.pressure = bmp.readPressure() / 100.0F;
  sensors.altitude = bmp.readAltitude(seaLevelPressure);
  
  // Set altitude reference on first reading
  if (firstReading) {
    altitudeOffset = sensors.altitude;
    firstReading = false;
  }
  sensors.altitude -= altitudeOffset; // Relative altitude
  
  // Simple low-pass filter for altitude
  static float filteredAlt = 0;
  filteredAlt = filteredAlt * 0.9 + sensors.altitude * 0.1;
  sensors.filteredAlt = filteredAlt;
  
  sensors.timestamp = micros();
}

// ============================================
// ATTITUDE ESTIMATION
// ============================================

void updateAttitude() {
  static unsigned long lastTime = 0;
  unsigned long now = micros();
  float dt = (now - lastTime) / 1000000.0;
  if (lastTime == 0) {
    lastTime = now;
    return;
  }
  dt = constrain(dt, 0.001, 0.01);
  
  // Calculate roll and pitch from accelerometer
  float accelRoll = atan2(sensors.accelY, sensors.accelZ) * 180.0 / PI;
  float accelPitch = atan2(-sensors.accelX, 
                     sqrt(sensors.accelY * sensors.accelY + sensors.accelZ * sensors.accelZ)) * 180.0 / PI;
  
  // Gyroscope integration
  rollRate = sensors.gyroX * 180.0 / PI;  // Convert to degrees/sec
  pitchRate = sensors.gyroY * 180.0 / PI;
  yawRate = sensors.gyroZ * 180.0 / PI;
  
  // Complementary filter (95% gyro, 5% accelerometer)
  roll = 0.95 * (roll + rollRate * dt) + 0.05 * accelRoll;
  pitch = 0.95 * (pitch + pitchRate * dt) + 0.05 * accelPitch;
  
  // Yaw from gyro only (no magnetometer)
  yaw += yawRate * dt;
  
  lastTime = now;
}

// ============================================
// RADIO COMMUNICATION
// ============================================

void checkRadio() {
  if (radio.available()) {
    RadioCommand received;
    radio.read(&received, sizeof(RadioCommand));
    
    // Verify checksum
    uint16_t calcChecksum = calculateChecksum(&received);
    if (calcChecksum == received.checksum) {
      rcCommand = received;
      lastRadioTime = millis();
      
      // Check for arm command (throttle low + switch combination)
      static bool armSwitchPrev = false;
      bool armSwitchNow = (rcCommand.switches & 0x01); // Use bit 0 for arming
      
      if (armSwitchNow && !armSwitchPrev && rcCommand.throttle < 50) {
        if (isArmed) {
          disarmMotors();
        } else {
          armMotors();
        }
      }
      armSwitchPrev = armSwitchNow;
      
      // Check for flight mode change
      static uint8_t modePrev = 0;
      uint8_t modeNow = (rcCommand.switches >> 1) & 0x03; // Bits 1-2 for mode
      
      if (modeNow != modePrev) {
        if (modeNow == 1 && isArmed) {
          currentMode = MODE_ALTITUDE_HOLD;
        } else {
          currentMode = MODE_ARMED;
        }
      }
      modePrev = modeNow;
    }
  }
  
  // Check for radio timeout
  if (millis() - lastRadioTime > RADIO_TIMEOUT) {
    if (isArmed && !failsafeActive) {
      failsafeActivate();
    }
  }
}

uint16_t calculateChecksum(RadioCommand* cmd) {
  uint16_t sum = 0;
  uint8_t* bytes = (uint8_t*)cmd;
  
  // XOR all bytes except checksum
  for (size_t i = 0; i < sizeof(RadioCommand) - sizeof(cmd->checksum); i++) {
    sum ^= bytes[i];
  }
  return sum;
}

// ============================================
// PID CONTROL
// ============================================

void updatePID(float dt) {
  // Map radio commands to setpoints
  float rollSetpoint = map(rcCommand.roll, -500, 500, -30, 30);     // ±30 degrees
  float pitchSetpoint = map(rcCommand.pitch, -500, 500, -30, 30);
  float yawSetpoint = map(rcCommand.yaw, -500, 500, -180, 180);     // ±180 deg/sec
  float throttleSetpoint = map(rcCommand.throttle, 0, 1000, MOTOR_IDLE, MOTOR_MAX);
  
  // Base throttle (from RC)
  float baseThrottle = throttleSetpoint;
  
  // PID calculations
  float rollCorrection = pidRoll.update(rollSetpoint, roll, dt);
  float pitchCorrection = pidPitch.update(pitchSetpoint, pitch, dt);
  float yawCorrection = pidYaw.update(yawSetpoint, yawRate, dt);
  
  // Altitude hold mode
  if (currentMode == MODE_ALTITUDE_HOLD) {
    float altSetpoint = sensors.filteredAlt; // Hold current altitude
    float altCorrection = pidAltitude.update(altSetpoint, sensors.filteredAlt, dt);
    baseThrottle += altCorrection;
    baseThrottle = constrain(baseThrottle, MOTOR_IDLE, MOTOR_MAX);
  }
  
  // Apply corrections to motors
  // Motor mixing for Quad X configuration
  motor1 = baseThrottle - pitchCorrection + rollCorrection + yawCorrection;  // Front Right
  motor2 = baseThrottle - pitchCorrection - rollCorrection - yawCorrection;  // Front Left
  motor3 = baseThrottle + pitchCorrection - rollCorrection + yawCorrection;  // Rear Left
  motor4 = baseThrottle + pitchCorrection + rollCorrection - yawCorrection;  // Rear Right
  
  // Constrain motor values
  motor1 = constrain(motor1, MOTOR_MIN, MOTOR_MAX);
  motor2 = constrain(motor2, MOTOR_MIN, MOTOR_MAX);
  motor3 = constrain(motor3, MOTOR_MIN, MOTOR_MAX);
  motor4 = constrain(motor4, MOTOR_MIN, MOTOR_MAX);
}

void calculateMotorMix() {
  // Motor mixing is already done in updatePID
  // This function is kept for compatibility
}

void setMotors() {
  esc1.writeMicroseconds(motor1);
  esc2.writeMicroseconds(motor2);
  esc3.writeMicroseconds(motor3);
  esc4.writeMicroseconds(motor4);
}

// ============================================
// SAFETY FUNCTIONS
// ============================================

void checkBattery() {
  // Read battery voltage through voltage divider
  int raw = analogRead(BATTERY_PIN);
  batteryVoltage = (raw / 4095.0) * 3.3 * BATTERY_FACTOR;
  
  // Check for low battery
  if (batteryVoltage < BATTERY_LOW) {
    // Low battery warning - slow beep
    if ((millis() / 1000) % 2 == 0) {
      tone(BUZZER_PIN, 1000, 100);
    }
  }
  
  // Critical battery - force landing
  if (batteryVoltage < BATTERY_CRITICAL && isArmed) {
    failsafeActivate();
  }
}

void failsafeActivate() {
  failsafeActive = true;
  currentMode = MODE_FAILSAFE;
  
  // Beep pattern for failsafe
  for (int i = 0; i < 3; i++) {
    tone(BUZZER_PIN, 2000, 100);
    delay(150);
  }
}

void armMotors() {
  if (!isArmed && !failsafeActive) {
    isArmed = true;
    currentMode = MODE_ARMED;
    armTime = millis();
    
    // Reset PID controllers
    pidRoll.reset();
    pidPitch.reset();
    pidYaw.reset();
    pidAltitude.reset();
    
    // Arm beep sequence
    tone(BUZZER_PIN, 1000, 100);
    delay(150);
    tone(BUZZER_PIN, 1500, 100);
    delay(150);
    tone(BUZZER_PIN, 2000, 100);
    
    Serial.println(F("✅ MOTORS ARMED"));
  }
}

void disarmMotors() {
  if (isArmed) {
    isArmed = false;
    currentMode = MODE_STANDBY;
    
    // Disarm beep
    tone(BUZZER_PIN, 800, 300);
    
    // Stop motors
    motor1 = motor2 = motor3 = motor4 = MOTOR_MIN;
    setMotors();
    
    Serial.println(F("⛔ MOTORS DISARMED"));
  }
}

// ============================================
// TELEMETRY & INDICATION
// ============================================

void sendTelemetry() {
  Serial.print(F("⏱️ "));
  Serial.print(millis());
  Serial.print(F(" | 📐 R:"));
  Serial.print(roll, 1);
  Serial.print(F(" P:"));
  Serial.print(pitch, 1);
  Serial.print(F(" Y:"));
  Serial.print(yaw, 1);
  Serial.print(F(" | 📊 A:"));
  Serial.print(sensors.filteredAlt, 2);
  Serial.print(F("m | ⚡ "));
  Serial.print(batteryVoltage, 2);
  Serial.print(F("V | "));
  
  // Status
  if (failsafeActive) Serial.print(F("⚠️ FAILSAFE"));
  else if (isArmed) {
    if (currentMode == MODE_ALTITUDE_HOLD) Serial.print(F("🔄 ALT HOLD"));
    else Serial.print(F("✈️ FLYING"));
  }
  else Serial.print(F("⏸️ STANDBY"));
  
  Serial.println();
}

void indicateStatus() {
  static unsigned long lastBlink = 0;
  unsigned long now = millis();
  
  if (failsafeActive) {
    // Fast red blink for failsafe
    if (now - lastBlink > 100) {
      digitalWrite(LED_ERROR, !digitalRead(LED_ERROR));
      lastBlink = now;
    }
    digitalWrite(LED_ARMED, LOW);
    digitalWrite(LED_STATUS, LOW);
  }
  else if (isArmed) {
    // Solid blue when armed
    digitalWrite(LED_ARMED, HIGH);
    digitalWrite(LED_ERROR, LOW);
    
    // Heartbeat when armed
    if (now - lastBlink > 1000) {
      digitalWrite(LED_STATUS, HIGH);
      delay(50);
      digitalWrite(LED_STATUS, LOW);
      lastBlink = now;
    }
  }
  else {
    // Slow blink when disarmed
    if (now - lastBlink > 500) {
      digitalWrite(LED_STATUS, !digitalRead(LED_STATUS));
      lastBlink = now;
    }
    digitalWrite(LED_ARMED, LOW);
    digitalWrite(LED_ERROR, LOW);
  }
}

// ============================================
// ESC CALIBRATION (Run once before first flight)
// ============================================

void calibrateESCs() {
  Serial.println(F("\n⚠️  ESC CALIBRATION MODE"));
  Serial.println(F("Disconnect battery, then follow instructions"));
  
  delay(2000);
  
  Serial.println(F("1. Set throttle to MAXIMUM"));
  Serial.println(F("2. Connect battery"));
  Serial.println(F("3. Wait for ESC beeps"));
  delay(5000);
  
  // Send max throttle
  esc1.writeMicroseconds(MOTOR_MAX);
  esc2.writeMicroseconds(MOTOR_MAX);
  esc3.writeMicroseconds(MOTOR_MAX);
  esc4.writeMicroseconds(MOTOR_MAX);
  
  Serial.println(F("4. After beeps, set throttle to MINIMUM"));
  delay(2000);
  
  // Send min throttle
  esc1.writeMicroseconds(MOTOR_MIN);
  esc2.writeMicroseconds(MOTOR_MIN);
  esc3.writeMicroseconds(MOTOR_MIN);
  esc4.writeMicroseconds(MOTOR_MIN);
  
  Serial.println(F("5. Calibration complete!"));
  delay(2000);
}

// ============================================
// UTILITY FUNCTIONS
// ============================================

float mapFloat(float x, float in_min, float in_max, float out_min, float out_max) {
  return (x - in_min) * (out_max - out_min) / (in_max - in_min) + out_min;
}
